# Example env vars consumed by FreightUtils.
# Copy to .env.local and fill in values for local dev.
# Production/preview values are managed via Vercel env.

# ─── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://www.freightutils.com
JWT_SECRET=

# ─── Vercel KV / Upstash Redis ────────────────────────────────────
# Auto-injected by the Vercel KV integration in production.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=
KV_REDIS_URL=

# ─── Email (Resend) ───────────────────────────────────────────────
RESEND_API_KEY=
RESEND_AUDIENCE_ID=

# ─── Payments (Stripe) ────────────────────────────────────────────
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# ─── Cron ─────────────────────────────────────────────────────────
# Shared secret used by /api/cron/* routes to authenticate Vercel Cron.
CRON_SECRET=

# ─── Sentry (error tracking) ──────────────────────────────────────
# Managed by the Sentry + Vercel marketplace integration.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ─── Monitoring (UptimeRobot) ─────────────────────────────────────
# Read-only API key used by /status page to fetch external probe stats.
UPTIMEROBOT_API_KEY=

# ─── Smoke test ───────────────────────────────────────────────────
# Pro-tier API key used by scripts/smoke-test.mjs to bypass the 25/day
# anonymous rate limit. Provision via: node scripts/provision-smoke-key.mjs
SMOKE_API_KEY=

# ─── Automation (local only — DO NOT add to Vercel env) ───────────
# Used by scripts/provision-smoke-key.mjs and similar admin scripts.
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=
